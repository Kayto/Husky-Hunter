# Development folder (local dev work, not for release)
Dev/*
!Dev/elta/
Dev/elta/*.jpg
Dev/elta/elta_sim.py
Dev/elta/ELTAC.BAS
Dev/elta/ELTAC.HBA

# Virtual environment
.venv/

# Python cache
__pycache__/

# Original documentation and ROM dumps
Docs/Orig_Docs/
Docs/Orig_ROMS/
Docs/hunter_manual_text.txt

# OS Terrain source data
Progs/Terrain/OS_Terrain/

# ASM subdirectories
Progs/ASM/

# HBA Format dev subfolder (test fixtures, dev tools) and HSYNC reference binaries
HBA_Format/Dev/
HBA_Format/HSYNC/

# BASIC subfolder (exclude DEMO1.BAS)
Progs/BASIC/DEMO1.BAS

# HBA binaries (exclude DEMO1.HBA)
HBA/DEMO1.HBA

# Binary format (development, private)
Progs/Terrain/TERRBIN.BAS
Progs/Terrain/TERRBIN_DEV.md
Progs/Terrain/TERRAIN_DEV.md
Progs/Terrain/CONTOUR.BIN
Progs/Terrain/Test/TERRBIN.BAS

# Diagnostic/test programs (development)
Progs/Terrain/DIAGFILE.BAS

# Generated image variant (development)
Progs/image_writer/HUSKY.BAS

# ROM analysis (private)
Docs/Orig_ROMS/ROM_ANALYSIS.md

# HCOM distribution files (downloaded separately)
HuskyHCOM/hcomw/*
!HuskyHCOM/hcomw/.gitkeep

# HSYNC files (device-specific, synced at runtime)
HuskyHCOM/HSYNC/*
!HuskyHCOM/HSYNC/.gitkeep

# HCOM runtime config (auto-generated, machine-specific)
HuskyHCOM/hcom-settings.ini
HuskyHCOM/hunter-sync.manifest

# Tide development scripts
Progs/Tide/*.py
Progs/Tide/__pycache__/

# TidePy directory
Progs/TidePy/

# Screenshots
Screenshot*.png

# Archives
*.7z

# PyInstaller build artefacts
build/
dist/
