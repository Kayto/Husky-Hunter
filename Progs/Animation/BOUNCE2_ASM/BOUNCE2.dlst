120   F68D              ; -------- calc_vram --------
121   F68D              ; In:  A = col (0-29)
122   F68D              ; Out: DE = wave_table[col]*30 + col
123   F68D              ; Clobbers A,HL,DE,C.  Preserves B
124   F68D              calc_vram:
125   63117   79                                      LD      C,A             ; save col
126   63118   95                                      LD      E,A
127   63119   22   0                               LD      D,0
128   63121   33 217 246                        LD      HL,wave_table
129   63124   25                                      ADD     HL,DE           ; HL -> wave_table[col]
130   63125  126                                      LD      A,(HL)          ; A = row
131   63126  111                                      LD      L,A
132   63127   38   0                               LD      H,0             ; row*30 = row*32 - row*2
133   63129   41                                      ADD     HL,HL           ; *2
134   63130  229                                      PUSH    HL
135   63131   41                                      ADD     HL,HL           ; *4
136   63132   41                                      ADD     HL,HL           ; *8
137   63133   41                                      ADD     HL,HL           ; *16
138   63134   41                                      ADD     HL,HL           ; *32
139   63135  209                                      POP     DE
140   63136  183                                      OR      A               ; OR A: clears carry flag without changing A
141   63137  237  82                               SBC     HL,DE           ; HL = row*30
142   63139   89                                      LD      E,C
143   63140   22   0                               LD      D,0
144   63142   25                                      ADD     HL,DE
145   63143  235                                      EX      DE,HL           ; DE = VRAM addr
146   63144  201                                      RET
