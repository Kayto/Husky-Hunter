 55   F634              draw1_loop:
 56   63028  197                                      PUSH    BC
 57   63029  205 169 246                        CALL    set_cursor
 58   63032  126                                      LD      A,(HL)
 59   63033   35                                      INC     HL
 60   63034  205 196 246                        CALL    write_byte
 61   63037  235                                      EX      DE,HL
 62   63038    1  30   0                        LD      BC,30
 63   63041    9                                      ADD     HL,BC
