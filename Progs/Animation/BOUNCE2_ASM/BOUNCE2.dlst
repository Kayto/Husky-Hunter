170   63176   62  12                               LD      A,0CH           ; cmd: write display data
171   63178  211  33                               OUT     (21H),A
172   63180  205 211 246                        CALL    wait_busy
173   63183  241                                      POP     AF
174   63184  211  32                               OUT     (20H),A
175   63186  201                                      RET
