 82   63071  235                                      EX      DE,HL
 83   63072  193                                      POP     BC
 84   63073   16 238                               DJNZ    draw2_loop
 85   F663
 86   63075   42  82 247                        LD      HL,(delay_ctr)
 87   F666              delay_loop:
 88   63078   43                                      DEC     HL
 89   63079  124                                      LD      A,H
 90   63080  181                                      OR      L
 91   63081   32 251                               JR      NZ,delay_loop
