 65   63043  193                                      POP     BC
 66   63044   16 238                               DJNZ    draw1_loop
 67   F646
 68   63046   58  65 247                        LD      A,(col2)        ; draw sprite 2 at new col2
 69   63049  205 141 246                        CALL    calc_vram
 70   63052   33  74 247                        LD      HL,sprite2
 71   63055    6   8                               LD      B,8
 72   F651
 73   F651              draw2_loop:
 74   63057  197                                      PUSH    BC
 75   63058  205 169 246                        CALL    set_cursor
 76   63061  126                                      LD      A,(HL)
 77   63062   35                                      INC     HL
 78   63063  205 196 246                        CALL    write_byte
 79   63066  235                                      EX      DE,HL
 80   63067    1  30   0                        LD      BC,30
