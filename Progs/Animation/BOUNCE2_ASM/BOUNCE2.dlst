 93   63083   14  11                               LD      C,0BH
 94   63085  205   5   0                        CALL    0005H           ; BDOS fn11 - console status
 95   63088  167                                      AND     A
 96   63089  202   5 246                        JP      Z,main_loop
 97   63092  201                                      RET
