153   63150  211  33                               OUT     (21H),A
154   63152  205 211 246                        CALL    wait_busy
155   63155  123                                      LD      A,E
156   63156  211  32                               OUT     (20H),A
157   63158  205 211 246                        CALL    wait_busy
158   63161   62  11                               LD      A,0BH           ; cmd: cursor address high
159   63163  211  33                               OUT     (21H),A
160   63165  205 211 246                        CALL    wait_busy
161   63168  122                                      LD      A,D
162   63169  211  32                               OUT     (20H),A
163   63171  201                                      RET
