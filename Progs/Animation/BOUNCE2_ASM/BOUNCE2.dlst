106   F67A              erase_loop:
107   63098  197                                      PUSH    BC
108   63099  205 169 246                        CALL    set_cursor
109   63102  175                                      XOR     A
110   63103  205 196 246                        CALL    write_byte
111   63106   98                                      LD      H,D
112   63107  107                                      LD      L,E
113   63108    1  30   0                        LD      BC,30
114   63111    9                                      ADD     HL,BC
115   63112  235                                      EX      DE,HL
116   63113  193                                      POP     BC
117   63114   16 238                               DJNZ    erase_loop
118   63116  201                                      RET
