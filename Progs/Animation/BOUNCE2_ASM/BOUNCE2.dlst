 28   F605              ; -------- MAIN LOOP --------
 29   F605              main_loop:
 30   62981   58  64 247                        LD      A,(col1)
 31   62984  205 117 246                        CALL    erase_at        ; erase sprite 1 at old col1
 32   62987   58  65 247                        LD      A,(col2)
 33   62990  205 117 246                        CALL    erase_at        ; erase sprite 2 at old col2
 34   F611
 35   62993   58  64 247                        LD      A,(col1)        ; advance col1 right, wrap 29->0
 36   62996   60                                      INC     A
 37   62997  254  30                               CP      30
 38   62999   56   1                               JR      C,no_wrap1
 39   63001  175                                      XOR     A
 40   F61A              no_wrap1:
 41   63002   50  64 247                        LD      (col1),A        ; LD (nn),A preserves A
 42   F61D
 43   63005   58  65 247                        LD      A,(col2)        ; advance col2 left, wrap 0->29
 44   63008  214   1                               SUB     1               ; carry set if was 0
 45   63010   48   2                               JR      NC,no_wrap2
 46   63012   62  29                               LD      A,29
 47   F626              no_wrap2:
 48   63014   50  65 247                        LD      (col2),A
 49   F629
 50   63017   58  64 247                        LD      A,(col1)        ; draw sprite 1 at new col1
 51   63020  205 141 246                        CALL    calc_vram       ; DE = VRAM addr
 52   63023   33  66 247                        LD      HL,sprite1
 53   63026    6   8                               LD      B,8
