 59   F626              ; --- UPDATE col with horizontal bounce ---
 60   63014   58  64 247                        LD      A,(col)
 61   63017   71                                      LD      B,A             ; B = old col
 62   63018   58  66 247                        LD      A,(dx)
 63   63021  128                                      ADD     A,B             ; A = col + dx
 64   63022  254  30                               CP      MAX_COL+1       ; unsigned: 0..MAX_COL ok
 65   63024   56   9                               JR      C,col_ok
 66   63026   58  66 247                        LD      A,(dx)
 67   63029  237  68                               NEG                     ; reverse direction
 68   63031   50  66 247                        LD      (dx),A
 69   63034  128                                      ADD     A,B             ; recompute with new dx
 70   F63B              col_ok:
 71   63035   50  64 247                        LD      (col),A
 72   F63E
 73   F63E              ; --- UPDATE row with vertical bounce ---
 74   63038   58  65 247                        LD      A,(row)
 75   63041   71                                      LD      B,A             ; B = old row
 76   63042   58  67 247                        LD      A,(dy)
 77   63045  128                                      ADD     A,B             ; A = row + dy
 78   63046  254  61                               CP      MAX_ROW+1
 79   63048   56   9                               JR      C,row_ok
 80   63050   58  67 247                        LD      A,(dy)
 81   63053  237  68                               NEG
 82   63055   50  67 247                        LD      (dy),A
 83   63058  128                                      ADD     A,B
 84   F653              row_ok:
 85   63059   50  65 247                        LD      (row),A
 86   F656
 87   F656              ; --- DRAW at new position ---
 88   63062   58  64 247                        LD      A,(col)
 89   63065   79                                      LD      C,A             ; C = col
 90   63066   58  65 247                        LD      A,(row)         ; A = row
 91   63069  205 137 246                        CALL    calc_vram
 92   63072   33  68 247                        LD      HL,sprite
 93   63075    6   4                               LD      B,4
