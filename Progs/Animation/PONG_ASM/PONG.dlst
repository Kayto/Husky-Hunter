 46   F614              erase_loop:
 47   62996  197                                      PUSH    BC
 48   62997  205 156 246                        CALL    set_cursor
 49   63000  175                                      XOR     A               ; A = 0: erase pixel data
 50   63001  205 183 246                        CALL    write_byte
 51   63004   98                                      LD      H,D
 52   63005  107                                      LD      L,E
 53   63006    1  30   0                        LD      BC,30
 54   63009    9                                      ADD     HL,BC
 55   63010  235                                      EX      DE,HL
 56   63011  193                                      POP     BC
