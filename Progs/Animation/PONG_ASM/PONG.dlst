 95   F665              draw_loop:
 96   63077  197                                      PUSH    BC
 97   63078  205 156 246                        CALL    set_cursor
 98   63081  126                                      LD      A,(HL)
 99   63082   35                                      INC     HL
100   63083  205 183 246                        CALL    write_byte
101   63086  235                                      EX      DE,HL
102   63087    1  30   0                        LD      BC,30
103   63090    9                                      ADD     HL,BC
104   63091  235                                      EX      DE,HL
105   63092  193                                      POP     BC
106   63093   16 238                               DJNZ    draw_loop
