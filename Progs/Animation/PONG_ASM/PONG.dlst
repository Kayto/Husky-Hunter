121   F689              ; -------- calc_vram --------
122   F689              ; In:  A = row (0-63), C = col (0-29)
123   F689              ; Out: DE = row*30 + col
124   F689              ; row*30 = row*32 - row*2  (shift-and-subtract, no MUL)
125   F689              ; Clobbers A,HL,DE.  Preserves B,C
126   F689              calc_vram:
127   63113  111                                      LD      L,A
128   63114   38   0                               LD      H,0             ; HL = row
129   63116   41                                      ADD     HL,HL           ; row*2
130   63117  229                                      PUSH    HL              ; save row*2
131   63118   41                                      ADD     HL,HL           ; row*4
132   63119   41                                      ADD     HL,HL           ; row*8
133   63120   41                                      ADD     HL,HL           ; row*16
134   63121   41                                      ADD     HL,HL           ; row*32
135   63122  209                                      POP     DE              ; DE = row*2
136   63123  183                                      OR      A               ; OR A: clears carry flag without changing A
137   63124  237  82                               SBC     HL,DE           ; HL = row*30
138   63126   89                                      LD      E,C             ; E = col
139   63127   22   0                               LD      D,0
140   63129   25                                      ADD     HL,DE           ; HL = row*30 + col
141   63130  235                                      EX      DE,HL           ; DE = VRAM addr
142   63131  201                                      RET
143   F69C
144   F69C              ; -------- set_cursor --------
145   F69C              ; In:  DE = VRAM offset.  Clobbers A.  Preserves HL,DE,BC
146   F69C              set_cursor:
