108   63095   42  72 247                        LD      HL,(delay_ctr)
109   F67A              delay_loop:
110   63098   43                                      DEC     HL
111   63099  124                                      LD      A,H
112   63100  181                                      OR      L
113   63101   32 251                               JR      NZ,delay_loop
114   F67F
115   63103   14  11                               LD      C,0BH
116   63105  205   5   0                        CALL    0005H           ; BDOS fn11 - console status
117   63108  167                                      AND     A
118   63109  202   5 246                        JP      Z,main_loop
119   63112  201                                      RET
