173   F6C6              ; -------- wait_busy --------
174   F6C6              ; Poll HD61830 status port until not busy (bit 7 = 0)
175   F6C6              wait_busy:
176   63174  219  33                               IN      A,(21H)
177   63176    7                                      RLCA
178   63177   56 251                               JR      C,wait_busy
179   63179  201                                      RET
