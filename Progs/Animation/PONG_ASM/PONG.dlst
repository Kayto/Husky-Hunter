161   F6B7              ; -------- write_byte --------
162   F6B7              ; In:  A = byte to write.  Clobbers A.  Preserves HL,DE,BC
163   F6B7              write_byte:
164   63159  245                                      PUSH    AF
165   63160  205 198 246                        CALL    wait_busy
166   63163   62  12                               LD      A,0CH           ; cmd: write display data
167   63165  211  33                               OUT     (21H),A
168   63167  205 198 246                        CALL    wait_busy
169   63170  241                                      POP     AF
170   63171  211  32                               OUT     (20H),A
171   63173  201                                      RET
