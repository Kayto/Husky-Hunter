148   63135   62  10                               LD      A,0AH           ; cmd: cursor address low
149   63137  211  33                               OUT     (21H),A
150   63139  205 198 246                        CALL    wait_busy
151   63142  123                                      LD      A,E
152   63143  211  32                               OUT     (20H),A
153   63145  205 198 246                        CALL    wait_busy
154   63148   62  11                               LD      A,0BH           ; cmd: cursor address high
155   63150  211  33                               OUT     (21H),A
156   63152  205 198 246                        CALL    wait_busy
157   63155  122                                      LD      A,D
158   63156  211  32                               OUT     (20H),A
159   63158  201                                      RET
