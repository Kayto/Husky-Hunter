 34   F605              ; -------- MAIN LOOP --------
 35   F605              main_loop:
 36   F605              ; Z80 has no LD C,(nn) - must go via A. Load both params then shuffle into place.
 37   62981   58  65 247                        LD      A,(row)         ; calc_vram wants: A=row, C=col
 38   62984   79                                      LD      C,A             ; park row in C
 39   62985   58  64 247                        LD      A,(col)
 40   62988   71                                      LD      B,A             ; park col in B
 41   62989  121                                      LD      A,C             ; A = row
 42   62990   72                                      LD      C,B             ; C = col
 43   62991  205 137 246                        CALL    calc_vram       ; DE = VRAM addr
 44   62994    6   4                               LD      B,4
