1 REM NEWS.HBA v1.0 ??? BBC News Feed
2 REM Receives headlines from PC over RS-232
3 REM By kayto 29/03/2026
4 REM For Husky Hunter (NSC800, 240x64 LCD)
5 REM BREAK key to exit
10 DIM L$(8,40)
12 KEY OFF:PRINT CHR$(1);
14 PRINT "BBC News Feed"
16 PRINT :PRINT "Awaiting serial...";
20 REM === SETUP SERIAL ===
22 POKE 63480,9:POKE 63481,9
26 POKE 63482,0:POKE 63493,0
100 REM === READ 8 LINES ===
102 FOR I=1 TO 8
104 LINPUT "",L$(I)
106 NEXT I
200 REM === DISPLAY ===
202 PRINT CHR$(1);
204 FOR I=1 TO 7
206 PRINT L$(I)
208 NEXT I
210 PRINT L$(8);
220 GOTO 100
