   5  0000              ;
   6  0000              ; Compatible with sjasmplus (Intel-style H-suffix hex).
   7  0000              ; Assemble with base address 0. All internal CALL/JP targets are
   8  0000              ; relative to start. BASIC patches them to real addresses at runtime
   9  0000              ; (patch loop, lines 9-11 of DefDat1.BAS).
  10  0000              ; EXCEPTION: CALL 0005H (CP/M BDOS vector) is NOT patched.
  11  0000              ;
  12  0000              ; MC stored as: DIM MC$(717,1) ; AD=VARPTR(MC$)-1
  13  0000              ;               1435 bytes at AD..AD+1434
  14  0000              ; Called by:   Z=CALL(AD)
  15  0000              ;
  16  0000              ; Param block at F605H (62981) - fixed user code area:
  17  0000              ;   +0         ship_row           current row of ship (0-56)
  18  0000              ;   +1         old_row            previous ship row (for erase)
  19  0000              ;   +2..+9     ship_sprite        8 bytes: 01 07 1F FF FF 1F 07 01
  20  0000              ;   +10,+11    frame_delay        little-endian word (5000 = 1388H)
  21  0000              ;   +12        star1_col          star 1 column (0-29)
  22  0000              ;   +13        star1_row          star 1 row    (0-56)
  23  0000              ;   +14        star2_col          star 2 column
  24  0000              ;   +15        star2_row          star 2 row
  25  0000              ;   +16        star3_col          star 3 column
  26  0000              ;   +17        star3_row          star 3 row
  27  0000              ;   +18        rng_seed           star RNG seed
  28  0000              ;   +19        shot_col           laser bolt column
  29  0000              ;   +20        shot_row           laser bolt row
  30  0000              ;   +21        shot_active        0=none, 1=in flight
  31  0000              ;   +22        enemy1_col         enemy 1 column
  32  0000              ;   +23        enemy1_row         enemy 1 row
  33  0000              ;   +24        enemy1_active      0=waiting, 1=on screen
  34  0000              ;   +25        enemy1_phase       movement phase (0-3 mod)
  35  0000              ;   +26..+33   enemy_sprite       8 bytes (shared): 1C A0 3E F1 F1 3E A0 1C
  36  0000              ;   +34        enemy1_dy          direction: 01=down, FF=up
  37  0000              ;   +35        enemy2_col         enemy 2 column
  38  0000              ;   +36        enemy2_row         enemy 2 row
  39  0000              ;   +37        enemy2_active      0=waiting, 1=on screen
  40  0000              ;   +38        enemy2_phase       movement phase
  41  0000              ;   +39        enemy2_dy          direction: 01=down, FF=up
  42  0000              ;   +40        kill_count         enemies destroyed (score, 0-FF)
  43  0000              ;   +41        wave               0=wave1, 1=wave2 (enemy2 enabled)
  44  0000              ;   +42        lives              lives remaining (0-3)
  45  0000              ;   +43        player_dead        0=alive, 1=dead (set by collision)
  46  0000              ;   +44..+51   heart_sprite       8 bytes: 36 7E 7E 3C 18 10 00 00
  47  0000              ;   +52        event_code         0=none 1=laser 2=explosion 3=death
  48  0000              ;
  49  0000              ;   Total: 53 bytes. Hardware limit: 80 bytes.
  50  0000              ;
  51  0000              ; BDOS entry: 0005H. BASIC uses fn=0BH (key available?), fn=06H (read key).
  52  0000              ;   LD C,0BH ; CALL 0005H ; test A
  53  0000              ;   LD C,06H ; LD E,0FFH  ; CALL 0005H -> A = key char
  54  0000
