 907  051F              ;  SUBROUTINES
 908  051F              ; ============================================================
 909  051F
 910  051F              ; hit_count_up: increment kill_count; if >= WAVE2_THRESHOLD set wave=1
 911  051F              hit_count_up:
 912  1311    58  45 246                        LD      A,(kill_count)
 913  1314    60                                      INC     A
 914  1315    50  45 246                        LD      (kill_count),A
 915  1318   254   5                               CP      WAVE2_THRESHOLD
 916  1320   216                                      RET     C               ; < threshold: return
 917  1321    62   1                               LD      A,1
 918  1323    50  46 246                        LD      (wave),A
 919  1326   201                                      RET
 920  052F
 921  052F              ; erase_rows: erase B rows starting at VRAM address in HL
 922  052F              ; Preserves B count via PUSH/POP BC.
 923  052F              ; On entry: HL=start VRAM addr, B=row count
 924  052F              erase_rows:
 925  1327   197                                      PUSH    BC
 926  1328   205 107   5                        CALL    set_cursor
 927  1331   175                                      XOR     A
 928  1332   205 134   5                        CALL    write_byte
 929  1335   205  80   5                        CALL    next_row
 930  1338   193                                      POP     BC
 931  1339    16 242                               DJNZ    erase_rows
 932  1341   201                                      RET
 933  053E
 934  053E              ; draw_sprite: draw B rows from (HL) at VRAM address in HL (outer), sprite in HL (inner)
 935  053E              ; On entry: HL=VRAM address (from calc_vram), HL also sprite pointer
 936  053E              ; Note: on entry HL = calc_vram result (VRAM address); sprite pointer passed separately
 937  053E              ; Actual call pattern: CALL calc_vram; LD HL,sprite_ptr; LD B,rows; CALL draw_sprite
 938  053E              ; HL = sprite data pointer. set_cursor uses DE as VRAM addr (set by calc_vram via EB).
 939  053E              draw_sprite:
 940  1342   197                                      PUSH    BC
 941  1343   205 107   5                        CALL    set_cursor
 942  1346   126                                      LD      A,(HL)
 943  1347    35                                      INC     HL
 944  1348   205 134   5                        CALL    write_byte
 945  1351   229                                      PUSH    HL
 946  1352   205  80   5                        CALL    next_row
 947  1355   225                                      POP     HL
 948  1356   193                                      POP     BC
 949  1357    16 239                               DJNZ    draw_sprite
 950  1359   201                                      RET
 951  0550
 952  0550              ; next_row: advance DE (VRAM address) by 30 (one pixel row = 30 bytes wide)
 953  0550              ; On entry: DE = current VRAM address
 954  0550              ; On exit:  DE = address of next row (DE + 30)
 955  0550              next_row:
 956  1360    98                                      LD      H,D
 957  1361   107                                      LD      L,E
 958  1362    17  30   0                        LD      DE,001EH        ; 30 decimal
 959  1365    25                                      ADD     HL,DE
 960  1366   235                                      EX      DE,HL
 961  1367   201                                      RET
 962  0558
 963  0558              ; calc_vram: calculate VRAM byte address from row A and column C
 964  0558              ; Formula: addr = C + (A * 30) ; because each row = 30 bytes
 965  0558              ; On entry: A=row (0-63), C=column (0-29)
 966  0558              ; On exit:  DE=VRAM address (0-1919)
 967  0558              ; Method: addr = C + A*30 = C + A*(32-2) = C + A*32 - A*2
 968  0558              ;         = C + (A<<5) - (A<<1)
 969  0558              ;         HL = A*1 = A; HL = A*2 (<<1); push; HL = A*4; *8; *16; *32;
 970  0558              ;         pop A*2; HL = A*32 - A*2 = A*30; add C -> HL = A*30+C
 971  0558              calc_vram:
 972  1368   111                                      LD      L,A             ; HL = A (row)
 973  1369    38   0                               LD      H,00H
 974  1371    41                                      ADD     HL,HL           ; HL = A*2
 975  1372   229                                      PUSH    HL              ; save A*2
 976  1373    41                                      ADD     HL,HL           ; HL = A*4
 977  1374    41                                      ADD     HL,HL           ; HL = A*8
 978  1375    41                                      ADD     HL,HL           ; HL = A*16
 979  1376    41                                      ADD     HL,HL           ; HL = A*32
 980  1377   209                                      POP     DE              ; DE = A*2
 981  1378   183                                      OR      A               ; clear carry
 982  1379   237  82                               SBC     HL,DE           ; HL = A*30
 983  1381    89                                      LD      E,C             ; E = col
 984  1382    22   0                               LD      D,00H
 985  1384    25                                      ADD     HL,DE           ; HL = A*30 + col
 986  1385   235                                      EX      DE,HL           ; DE = VRAM address
 987  1386   201                                      RET
 988  056B
 989  056B              ; set_cursor: set HD61830 cursor to VRAM address in DE
 990  056B              ; Commands: 0AH (set cursor low byte), 0BH (set cursor high byte)
 991  056B              ; LCD port 21H=command, 20H=data
 992  056B              set_cursor:
 993  1387   205 149   5                        CALL    wait_busy
 994  1390    62  10                               LD      A,0AH           ; Set Cursor Address (low)
 995  1392   211  33                               OUT     (LCD_CMD),A
 996  1394   205 149   5                        CALL    wait_busy
 997  1397   123                                      LD      A,E             ; low byte of address
 998  1398   211  32                               OUT     (LCD_DATA),A
 999  1400   205 149   5                        CALL    wait_busy
1000  1403    62  11                               LD      A,0BH           ; Set Cursor Address (high)
1001  1405   211  33                               OUT     (LCD_CMD),A
1002  1407   205 149   5                        CALL    wait_busy
1003  1410   122                                      LD      A,D             ; high byte of address
1004  1411   211  32                               OUT     (LCD_DATA),A
1005  1413   201                                      RET
1006  0586
1007  0586              ; write_byte: write A to HD61830 display RAM at current cursor
1008  0586              ; Command: 0CH (Write Display RAM; cursor auto-increments)
1009  0586              write_byte:
1010  1414   245                                      PUSH    AF
1011  1415   205 149   5                        CALL    wait_busy
1012  1418    62  12                               LD      A,0CH           ; Write Display RAM
1013  1420   211  33                               OUT     (LCD_CMD),A
1014  1422   205 149   5                        CALL    wait_busy
1015  1425   241                                      POP     AF
1016  1426   211  32                               OUT     (LCD_DATA),A
1017  1428   201                                      RET
1018  0595
1019  0595              ; wait_busy: poll HD61830 status on port 21H until not busy
1020  0595              ; Bit 7 of status = busy flag (1=busy). RLCA shifts bit7 into carry.
1021  0595              wait_busy:
1022  1429   219  33                               IN      A,(LCD_CMD)     ; read status
1023  1431     7                                      RLCA                    ; bit7 -> carry
1024  1432    56 251                               JR      C,wait_busy     ; carry set -> busy, loop
1025  1434   201                                      RET
1026  059B
# file closed: DEFEND.asm
