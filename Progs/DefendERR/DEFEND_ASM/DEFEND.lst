 295  0148              ; --- Heart 2: draw or erase at row 16 (needs lives >= 3) ---
 296  0148 3A 2F F6                     LD      A,(lives)
 297  014B FE 03                        CP      3
 298  014D 30 0E                        JR      NC,h2_full
 299  014F 3E 10                        LD      A,16
 300  0151 0E 00                        LD      C,HEART_COL
 301  0153 CD 58 05                     CALL    calc_vram
 302  0156 06 08                        LD      B,8
 303  0158 CD 2F 05                     CALL    erase_rows
