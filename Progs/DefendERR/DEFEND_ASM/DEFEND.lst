 425  021D 32 1A F6                     LD      (shot_active),A
 426  0220 18 1E                        JR      skip_shot
 427  0222
 428  0222              shot_store:
 429  0222 32 18 F6                     LD      (shot_col),A
 430  0225 47                           LD      B,A             ; B = new col
 431  0226
 432  0226                              ; draw shot at new position
 433  0226 3A 19 F6                     LD      A,(shot_row)
 434  0229 48                           LD      C,B
 435  022A CD 58 05                     CALL    calc_vram
 436  022D CD 6B 05                     CALL    set_cursor
 437  0230 3E 3C                        LD      A,SHOT_BYTE_TOP
 438  0232 CD 86 05                     CALL    write_byte
 439  0235 CD 50 05                     CALL    next_row
 440  0238 CD 6B 05                     CALL    set_cursor
 441  023B 3E 3C                        LD      A,SHOT_BYTE_BOT
 442  023D CD 86 05                     CALL    write_byte
 443  0240
 444  0240              skip_shot:
 445  0240
 446  0240              ; ============================================================
 447  0240              ;  COLLISION CHECK: shot vs enemy 1
 448  0240              ; ============================================================
 449  0240 3A 1A F6                     LD      A,(shot_active)
 450  0243 B7                           OR      A
 451  0244 28 5D                        JR      Z,try_e2_coll   ; no shot -> try enemy2
 452  0246
 453  0246 3A 1D F6                     LD      A,(enemy1_active)
 454  0249 B7                           OR      A
 455  024A 28 57                        JR      Z,try_e2_coll   ; enemy1 not active
 456  024C
 457  024C                              ; same column?
 458  024C 3A 18 F6                     LD      A,(shot_col)
 459  024F 47                           LD      B,A
 460  0250 3A 1B F6                     LD      A,(enemy1_col)
 461  0253 B8                           CP      B
 462  0254 20 4D                        JR      NZ,try_e2_coll
 463  0256
 464  0256                              ; row overlap? shot_row - enemy1_row < 8
 465  0256 3A 19 F6                     LD      A,(shot_row)
 466  0259 47                           LD      B,A
 467  025A 3A 1C F6                     LD      A,(enemy1_row)
 468  025D 4F                           LD      C,A
 469  025E 78                           LD      A,B             ; A = shot_row
 470  025F 91                           SUB     C               ; A = shot_row - enemy1_row (carry = enemy above)
 471  0260 FE 08                        CP      8               ; if >= 8 (or wrapped), not a hit
 472  0262 30 3F                        JR      NC,try_e2_coll  ; miss
 473  0264
 474  0264                              ; --- HIT enemy 1: erase shot ---
 475  0264 3A 18 F6                     LD      A,(shot_col)
 476  0267 47                           LD      B,A
 477  0268 3A 19 F6                     LD      A,(shot_row)
 478  026B 48                           LD      C,B
 479  026C CD 58 05                     CALL    calc_vram
