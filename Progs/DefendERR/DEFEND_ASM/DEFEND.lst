 130  0010              main_loop:
 131  0010
 132  0010              ; --- Star 1: erase old position ---
 133  0010              ; A=row, C=col -> calc_vram uses A=row, C=col
 134  0010              ; Load col into B first; row into A; LD C,B copies col into C
 135  0010 3A 11 F6                     LD      A,(star1_col)
 136  0013 47                           LD      B,A
 137  0014 3A 12 F6                     LD      A,(star1_row)
 138  0017 48                           LD      C,B
 139  0018 CD 58 05                     CALL    calc_vram
 140  001B CD 6B 05                     CALL    set_cursor
 141  001E AF                           XOR     A
 142  001F CD 86 05                     CALL    write_byte
 143  0022 CD 50 05                     CALL    next_row
 144  0025 CD 6B 05                     CALL    set_cursor
 145  0028 AF                           XOR     A
 146  0029 CD 86 05                     CALL    write_byte
 147  002C              ; --- Star 1: scroll (move left), wrap at col 0 ---
 148  002C 78                           LD      A,B             ; A = old col (B still holds it)
 149  002D B7                           OR      A               ; test zero
 150  002E 28 03                        JR      Z,s1_wrap
 151  0030 3D                           DEC     A
 152  0031 18 0F                        JR      s1_store
