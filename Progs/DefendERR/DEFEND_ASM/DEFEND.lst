 119  0000 3A 05 F6                     LD      A,(ship_row)
 120  0003 0E 02                        LD      C,SHIP_COL
 121  0005 CD 58 05                     CALL    calc_vram
 122  0008 21 07 F6                     LD      HL,ship_sprite
 123  000B 06 08                        LD      B,SHIP_HEIGHT
 124  000D CD 3E 05                     CALL    draw_sprite
