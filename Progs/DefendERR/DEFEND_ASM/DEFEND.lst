 310  0167 06 08                        LD      B,8
 311  0169 CD 3E 05                     CALL    draw_sprite
 312  016C              h2_done:
 313  016C
 314  016C              ; --- Save ship_row -> old_row ---
 315  016C 3A 05 F6                     LD      A,(ship_row)
 316  016F 32 06 F6                     LD      (old_row),A
 317  0172
 318  0172              ; --- Key poll: BDOS fn 0BH (returns A=0xFF if key available) ---
 319  0172 0E 0B                        LD      C,0BH
 320  0174 CD 05 00                     CALL    BDOS
 321  0177 A7                           AND     A               ; test A
 322  0178 28 53                        JR      Z,no_key        ; zero -> no key
 323  017A
 324  017A              ; --- Key read: BDOS fn 06H, E=FFH (read key, no echo) ---
 325  017A 0E 06                        LD      C,06H
 326  017C 1E FF                        LD      E,0FFH
 327  017E CD 05 00                     CALL    BDOS
 328  0181
 329  0181 FE 1B                        CP      KEY_ESC
 330  0183 20 01                        JR      NZ,not_esc
 331  0185 C9                           RET                     ; ESC -> exit to BASIC
 332  0186
 333  0186              not_esc:
 334  0186 F6 20                        OR      KEY_SPACE       ; force bit 5 (lowercase -> uppercase range)
 335  0188 FE 20                        CP      KEY_SPACE
 336  018A 28 24                        JR      Z,fire_shot
 337  018C FE 61                        CP      KEY_A
 338  018E 28 06                        JR      Z,ship_up
 339  0190 FE 7A                        CP      KEY_Z
 340  0192 28 0C                        JR      Z,ship_down
 341  0194 18 37                        JR      no_key
 342  0196
 343  0196              ship_up:
 344  0196 3A 05 F6                     LD      A,(ship_row)
 345  0199 D6 02                        SUB     SHIP_SPEED      ; move up (lower row number)
 346  019B 30 0E                        JR      NC,ship_store
 347  019D AF                           XOR     A               ; clamp to 0
 348  019E 18 0B                        JR      ship_store
 349  01A0
 350  01A0              ship_down:
 351  01A0 3A 05 F6                     LD      A,(ship_row)
 352  01A3 C6 02                        ADD     A,SHIP_SPEED    ; move down (higher row number)
 353  01A5 FE 39                        CP      MAX_ROW+1
 354  01A7 38 02                        JR      C,ship_store
 355  01A9 3E 38                        LD      A,MAX_ROW       ; clamp to MAX_ROW
 356  01AB
 357  01AB              ship_store:
 358  01AB 32 05 F6                     LD      (ship_row),A
 359  01AE 18 1D                        JR      no_key
 360  01B0
 361  01B0              fire_shot:
 362  01B0 3A 1A F6                     LD      A,(shot_active)
 363  01B3 B7                           OR      A
 364  01B4 20 17                        JR      NZ,no_key       ; already a shot in flight
 365  01B6 3E 03                        LD      A,SHIP_COL+1    ; shot starts one column right of ship
 366  01B8 32 18 F6                     LD      (shot_col),A
 367  01BB 3A 05 F6                     LD      A,(ship_row)
 368  01BE C6 03                        ADD     A,3             ; shot vertically centred on ship
 369  01C0 32 19 F6                     LD      (shot_row),A
 370  01C3 3E 01                        LD      A,1
 371  01C5 32 1A F6                     LD      (shot_active),A
 372  01C8                              ; event_code = 1 (laser fired)
 373  01C8 3E 01                        LD      A,1
 374  01CA 32 39 F6                     LD      (event_code),A
 375  01CD
 376  01CD              no_key:
 377  01CD
 378  01CD              ; --- Ship update: erase and redraw only if row changed ---
 379  01CD 3A 06 F6                     LD      A,(old_row)
 380  01D0 47                           LD      B,A             ; B = old_row
 381  01D1 3A 05 F6                     LD      A,(ship_row)
 382  01D4 B8                           CP      B               ; same as before?
 383  01D5 28 1B                        JR      Z,after_ship_move
 384  01D7
 385  01D7 78                           LD      A,B             ; erase at old_row
 386  01D8 0E 02                        LD      C,SHIP_COL
 387  01DA CD 58 05                     CALL    calc_vram
 388  01DD 06 08                        LD      B,SHIP_HEIGHT
 389  01DF CD 2F 05                     CALL    erase_rows
 390  01E2
 391  01E2 3A 05 F6                     LD      A,(ship_row)    ; draw at new row
 392  01E5 0E 02                        LD      C,SHIP_COL
 393  01E7 CD 58 05                     CALL    calc_vram
 394  01EA 21 07 F6                     LD      HL,ship_sprite
 395  01ED 06 08                        LD      B,SHIP_HEIGHT
 396  01EF CD 3E 05                     CALL    draw_sprite
 397  01F2
 398  01F2              after_ship_move:
 399  01F2
 400  01F2              ; --- Projectile update ---
 401  01F2 3A 1A F6                     LD      A,(shot_active)
 402  01F5 B7                           OR      A
 403  01F6 28 48                        JR      Z,skip_shot     ; no shot -> skip
 404  01F8
 405  01F8                              ; erase shot at current position
 406  01F8 3A 18 F6                     LD      A,(shot_col)
 407  01FB 47                           LD      B,A
 408  01FC 3A 19 F6                     LD      A,(shot_row)
 409  01FF 48                           LD      C,B
 410  0200 CD 58 05                     CALL    calc_vram
 411  0203 CD 6B 05                     CALL    set_cursor
 412  0206 AF                           XOR     A
 413  0207 CD 86 05                     CALL    write_byte
 414  020A CD 50 05                     CALL    next_row
 415  020D CD 6B 05                     CALL    set_cursor
 416  0210 AF                           XOR     A
 417  0211 CD 86 05                     CALL    write_byte
 418  0214
 419  0214                              ; advance shot one column right
 420  0214 3A 18 F6                     LD      A,(shot_col)
 421  0217 3C                           INC     A
 422  0218 FE 1E                        CP      MAX_COL+1       ; past right edge?
 423  021A 38 06                        JR      C,shot_store
