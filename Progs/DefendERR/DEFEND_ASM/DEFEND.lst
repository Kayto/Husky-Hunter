 891  050F              ; --- Frame delay: LD HL,(frame_delay); loop DEC HL until zero ---
 892  050F 2A 0F F6                     LD      HL,(frame_delay)
 893  0512              delay_loop:
 894  0512 2B                           DEC     HL
 895  0513 7C                           LD      A,H
 896  0514 B5                           OR      L
 897  0515 20 FB                        JR      NZ,delay_loop
 898  0517
 899  0517              ; --- End of frame: if event_code != 0, RET to BASIC for sound ---
 900  0517 3A 39 F6                     LD      A,(event_code)
 901  051A B7                           OR      A
 902  051B C0                           RET     NZ              ; BASIC dispatches on EV code
 903  051C
 904  051C C3 10 00                     JP      main_loop
 905  051F
 906  051F              ; ============================================================
 907  051F              ;  SUBROUTINES
 908  051F              ; ============================================================
 909  051F
 910  051F              ; hit_count_up: increment kill_count; if >= WAVE2_THRESHOLD set wave=1
 911  051F              hit_count_up:
 912  051F 3A 2D F6                     LD      A,(kill_count)
 913  0522 3C                           INC     A
 914  0523 32 2D F6                     LD      (kill_count),A
 915  0526 FE 05                        CP      WAVE2_THRESHOLD
 916  0528 D8                           RET     C               ; < threshold: return
 917  0529 3E 01                        LD      A,1
 918  052B 32 2E F6                     LD      (wave),A
 919  052E C9                           RET
 920  052F
 921  052F              ; erase_rows: erase B rows starting at VRAM address in HL
 922  052F              ; Preserves B count via PUSH/POP BC.
 923  052F              ; On entry: HL=start VRAM addr, B=row count
 924  052F              erase_rows:
 925  052F C5                           PUSH    BC
 926  0530 CD 6B 05                     CALL    set_cursor
 927  0533 AF                           XOR     A
 928  0534 CD 86 05                     CALL    write_byte
 929  0537 CD 50 05                     CALL    next_row
 930  053A C1                           POP     BC
 931  053B 10 F2                        DJNZ    erase_rows
 932  053D C9                           RET
 933  053E
 934  053E              ; draw_sprite: draw B rows from (HL) at VRAM address in HL (outer), sprite in HL (inner)
 935  053E              ; On entry: HL=VRAM address (from calc_vram), HL also sprite pointer
 936  053E              ; Note: on entry HL = calc_vram result (VRAM address); sprite pointer passed separately
 937  053E              ; Actual call pattern: CALL calc_vram; LD HL,sprite_ptr; LD B,rows; CALL draw_sprite
 938  053E              ; HL = sprite data pointer. set_cursor uses DE as VRAM addr (set by calc_vram via EB).
 939  053E              draw_sprite:
 940  053E C5                           PUSH    BC
 941  053F CD 6B 05                     CALL    set_cursor
 942  0542 7E                           LD      A,(HL)
 943  0543 23                           INC     HL
 944  0544 CD 86 05                     CALL    write_byte
 945  0547 E5                           PUSH    HL
 946  0548 CD 50 05                     CALL    next_row
 947  054B E1                           POP     HL
 948  054C C1                           POP     BC
 949  054D 10 EF                        DJNZ    draw_sprite
 950  054F C9                           RET
 951  0550
 952  0550              ; next_row: advance DE (VRAM address) by 30 (one pixel row = 30 bytes wide)
 953  0550              ; On entry: DE = current VRAM address
 954  0550              ; On exit:  DE = address of next row (DE + 30)
 955  0550              next_row:
 956  0550 62                           LD      H,D
 957  0551 6B                           LD      L,E
 958  0552 11 1E 00                     LD      DE,001EH        ; 30 decimal
 959  0555 19                           ADD     HL,DE
 960  0556 EB                           EX      DE,HL
 961  0557 C9                           RET
 962  0558
 963  0558              ; calc_vram: calculate VRAM byte address from row A and column C
 964  0558              ; Formula: addr = C + (A * 30) ; because each row = 30 bytes
 965  0558              ; On entry: A=row (0-63), C=column (0-29)
 966  0558              ; On exit:  DE=VRAM address (0-1919)
 967  0558              ; Method: addr = C + A*30 = C + A*(32-2) = C + A*32 - A*2
 968  0558              ;         = C + (A<<5) - (A<<1)
 969  0558              ;         HL = A*1 = A; HL = A*2 (<<1); push; HL = A*4; *8; *16; *32;
 970  0558              ;         pop A*2; HL = A*32 - A*2 = A*30; add C -> HL = A*30+C
 971  0558              calc_vram:
 972  0558 6F                           LD      L,A             ; HL = A (row)
 973  0559 26 00                        LD      H,00H
 974  055B 29                           ADD     HL,HL           ; HL = A*2
 975  055C E5                           PUSH    HL              ; save A*2
 976  055D 29                           ADD     HL,HL           ; HL = A*4
 977  055E 29                           ADD     HL,HL           ; HL = A*8
 978  055F 29                           ADD     HL,HL           ; HL = A*16
 979  0560 29                           ADD     HL,HL           ; HL = A*32
 980  0561 D1                           POP     DE              ; DE = A*2
 981  0562 B7                           OR      A               ; clear carry
 982  0563 ED 52                        SBC     HL,DE           ; HL = A*30
 983  0565 59                           LD      E,C             ; E = col
 984  0566 16 00                        LD      D,00H
 985  0568 19                           ADD     HL,DE           ; HL = A*30 + col
 986  0569 EB                           EX      DE,HL           ; DE = VRAM address
 987  056A C9                           RET
 988  056B
 989  056B              ; set_cursor: set HD61830 cursor to VRAM address in DE
 990  056B              ; Commands: 0AH (set cursor low byte), 0BH (set cursor high byte)
 991  056B              ; LCD port 21H=command, 20H=data
 992  056B              set_cursor:
 993  056B CD 95 05                     CALL    wait_busy
 994  056E 3E 0A                        LD      A,0AH           ; Set Cursor Address (low)
 995  0570 D3 21                        OUT     (LCD_CMD),A
 996  0572 CD 95 05                     CALL    wait_busy
 997  0575 7B                           LD      A,E             ; low byte of address
 998  0576 D3 20                        OUT     (LCD_DATA),A
 999  0578 CD 95 05                     CALL    wait_busy
1000  057B 3E 0B                        LD      A,0BH           ; Set Cursor Address (high)
1001  057D D3 21                        OUT     (LCD_CMD),A
1002  057F CD 95 05                     CALL    wait_busy
1003  0582 7A                           LD      A,D             ; high byte of address
1004  0583 D3 20                        OUT     (LCD_DATA),A
1005  0585 C9                           RET
1006  0586
1007  0586              ; write_byte: write A to HD61830 display RAM at current cursor
1008  0586              ; Command: 0CH (Write Display RAM; cursor auto-increments)
1009  0586              write_byte:
1010  0586 F5                           PUSH    AF
1011  0587 CD 95 05                     CALL    wait_busy
1012  058A 3E 0C                        LD      A,0CH           ; Write Display RAM
1013  058C D3 21                        OUT     (LCD_CMD),A
1014  058E CD 95 05                     CALL    wait_busy
1015  0591 F1                           POP     AF
1016  0592 D3 20                        OUT     (LCD_DATA),A
1017  0594 C9                           RET
1018  0595
1019  0595              ; wait_busy: poll HD61830 status on port 21H until not busy
1020  0595              ; Bit 7 of status = busy flag (1=busy). RLCA shifts bit7 into carry.
1021  0595              wait_busy:
1022  0595 DB 21                        IN      A,(LCD_CMD)     ; read status
1023  0597 07                           RLCA                    ; bit7 -> carry
1024  0598 38 FB                        JR      C,wait_busy     ; carry set -> busy, loop
1025  059A C9                           RET
1026  059B
# file closed: DEFEND.asm
