# file opened: DEFEND.asm
   1  0000              ; DEFEND.asm - Z80 source equivalent of gen_defend11.py
   2  0000              ; DEFENDER game engine (Prerelease v0.1) for the Husky Hunter
   3  0000              ; By Kayto April/May 2026
   4  0000              ; Licensed under the MIT License. See LICENSE file for details.
   5  0000              ;
   6  0000              ; Compatible with sjasmplus (Intel-style H-suffix hex).
   7  0000              ; Assemble with base address 0. All internal CALL/JP targets are
   8  0000              ; relative to start. BASIC patches them to real addresses at runtime
   9  0000              ; (patch loop, lines 9-11 of DefDat1.BAS).
  10  0000              ; EXCEPTION: CALL 0005H (CP/M BDOS vector) is NOT patched.
  11  0000              ;
  12  0000              ; MC stored as: DIM MC$(717,1) ; AD=VARPTR(MC$)-1
  13  0000              ;               1435 bytes at AD..AD+1434
  14  0000              ; Called by:   Z=CALL(AD)
  15  0000              ;
  16  0000              ; Param block at F605H (62981) - fixed user code area:
  17  0000              ;   +0         ship_row           current row of ship (0-56)
  18  0000              ;   +1         old_row            previous ship row (for erase)
  19  0000              ;   +2..+9     ship_sprite        8 bytes: 01 07 1F FF FF 1F 07 01
  20  0000              ;   +10,+11    frame_delay        little-endian word (5000 = 1388H)
  21  0000              ;   +12        star1_col          star 1 column (0-29)
  22  0000              ;   +13        star1_row          star 1 row    (0-56)
  23  0000              ;   +14        star2_col          star 2 column
  24  0000              ;   +15        star2_row          star 2 row
  25  0000              ;   +16        star3_col          star 3 column
  26  0000              ;   +17        star3_row          star 3 row
  27  0000              ;   +18        rng_seed           star RNG seed
  28  0000              ;   +19        shot_col           laser bolt column
  29  0000              ;   +20        shot_row           laser bolt row
  30  0000              ;   +21        shot_active        0=none, 1=in flight
  31  0000              ;   +22        enemy1_col         enemy 1 column
  32  0000              ;   +23        enemy1_row         enemy 1 row
  33  0000              ;   +24        enemy1_active      0=waiting, 1=on screen
  34  0000              ;   +25        enemy1_phase       movement phase (0-3 mod)
  35  0000              ;   +26..+33   enemy_sprite       8 bytes (shared): 1C A0 3E F1 F1 3E A0 1C
  36  0000              ;   +34        enemy1_dy          direction: 01=down, FF=up
  37  0000              ;   +35        enemy2_col         enemy 2 column
  38  0000              ;   +36        enemy2_row         enemy 2 row
  39  0000              ;   +37        enemy2_active      0=waiting, 1=on screen
  40  0000              ;   +38        enemy2_phase       movement phase
  41  0000              ;   +39        enemy2_dy          direction: 01=down, FF=up
  42  0000              ;   +40        kill_count         enemies destroyed (score, 0-FF)
  43  0000              ;   +41        wave               0=wave1, 1=wave2 (enemy2 enabled)
  44  0000              ;   +42        lives              lives remaining (0-3)
  45  0000              ;   +43        player_dead        0=alive, 1=dead (set by collision)
  46  0000              ;   +44..+51   heart_sprite       8 bytes: 36 7E 7E 3C 18 10 00 00
  47  0000              ;   +52        event_code         0=none 1=laser 2=explosion 3=death
  48  0000              ;
  49  0000              ;   Total: 53 bytes. Hardware limit: 80 bytes.
  50  0000              ;
  51  0000              ; BDOS entry: 0005H. BASIC uses fn=0BH (key available?), fn=06H (read key).
  52  0000              ;   LD C,0BH ; CALL 0005H ; test A
  53  0000              ;   LD C,06H ; LD E,0FFH  ; CALL 0005H -> A = key char
  54  0000
  55  0000              ; ============================================================
  56  0000              ;  EQUATES
  57  0000              ; ============================================================
  58  0000
  59  0000              PARAM_BASE      EQU     0F605H
  60  0000
  61  0000              ship_row        EQU     PARAM_BASE+0
  62  0000              old_row         EQU     PARAM_BASE+1
  63  0000              ship_sprite     EQU     PARAM_BASE+2
  64  0000              frame_delay     EQU     PARAM_BASE+10
  65  0000              star1_col       EQU     PARAM_BASE+12
  66  0000              star1_row       EQU     PARAM_BASE+13
  67  0000              star2_col       EQU     PARAM_BASE+14
  68  0000              star2_row       EQU     PARAM_BASE+15
  69  0000              star3_col       EQU     PARAM_BASE+16
  70  0000              star3_row       EQU     PARAM_BASE+17
  71  0000              rng_seed        EQU     PARAM_BASE+18
  72  0000              shot_col        EQU     PARAM_BASE+19
  73  0000              shot_row        EQU     PARAM_BASE+20
  74  0000              shot_active     EQU     PARAM_BASE+21
  75  0000              enemy1_col      EQU     PARAM_BASE+22
  76  0000              enemy1_row      EQU     PARAM_BASE+23
  77  0000              enemy1_active   EQU     PARAM_BASE+24
  78  0000              enemy1_phase    EQU     PARAM_BASE+25
  79  0000              enemy_sprite    EQU     PARAM_BASE+26   ; 8 bytes, shared between enemies
  80  0000              enemy1_dy       EQU     PARAM_BASE+34
  81  0000              enemy2_col      EQU     PARAM_BASE+35
  82  0000              enemy2_row      EQU     PARAM_BASE+36
  83  0000              enemy2_active   EQU     PARAM_BASE+37
  84  0000              enemy2_phase    EQU     PARAM_BASE+38
  85  0000              enemy2_dy       EQU     PARAM_BASE+39
  86  0000              kill_count      EQU     PARAM_BASE+40
  87  0000              wave            EQU     PARAM_BASE+41
  88  0000              lives           EQU     PARAM_BASE+42
  89  0000              player_dead     EQU     PARAM_BASE+43
  90  0000              heart_sprite    EQU     PARAM_BASE+44   ; 8 bytes
  91  0000              event_code      EQU     PARAM_BASE+52
  92  0000
  93  0000              SHIP_COL        EQU     2
  94  0000              SHIP_HEIGHT     EQU     8
  95  0000              ENEMY_HEIGHT    EQU     8
  96  0000              SHIP_SPEED      EQU     2
  97  0000              MAX_COL         EQU     29
  98  0000              MAX_ROW         EQU     56
  99  0000              HEART_COL       EQU     0
 100  0000              STAR_BYTE_TOP   EQU     03H
 101  0000              STAR_BYTE_BOT   EQU     01H
 102  0000              SHOT_BYTE_TOP   EQU     3CH
 103  0000              SHOT_BYTE_BOT   EQU     3CH
 104  0000              WAVE2_THRESHOLD EQU     5
 105  0000              KEY_A           EQU     61H
 106  0000              KEY_Z           EQU     7AH
 107  0000              KEY_SPACE       EQU     20H
 108  0000              KEY_ESC         EQU     1BH
 109  0000              BDOS            EQU     0005H
 110  0000              LCD_CMD         EQU     21H
 111  0000              LCD_DATA        EQU     20H
