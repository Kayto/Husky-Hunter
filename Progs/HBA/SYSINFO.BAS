1 REM SYSINFO.HBA
2 REM Hunter diagnostic and repair
3 REM By kayto 21/03/2026
10 REM === PAGE 1: MEMORY & POWER ===
12 KEY OFF
15 PRINT "=== SYSINFO ==="
20 PRINT
25 PRINT "  Free mem:";FRE(0)
27 AL=PEEK(63551)+PEEK(63552)*256:DL=PEEK(63553)+PEEK(63554)*256
28 PRINT "  ALIM:";AL;"  DEF:";DL
30 PRINT
50 P1=PEEK(63416):P2=PEEK(63419):P3=PEEK(63415)
55 IF P1=0 AND P2=0 THEN PRINT "  Power-off: OK":PRINT:GOTO 115
60 PRINT "  Power-off: STUCK!"
70 PRINT "  APH:";P3;" NYM:";P1;" FOR:";P2
80 PRINT "  Fix? (Y/N)";
90 INCHR AK:PRINT CHR$(AK)
95 IF AK=89 OR AK=121 THEN POKE 63415,0:POKE 63416,0:POKE 63419,0:PRINT "  Fixed"
115 GOSUB 900
120 REM === PAGE 2: DISPLAY & KEYBOARD ===
125 PRINT "  --Display--"
130 CURON:PRINT "  Cursor: on"
170 SCREEN 0:PRINT "  Screen: 0 (text)"
173 PRINT
175 PRINT "  --Keyboard--"
186 IP=PEEK(63360):CK=PEEK(65266)
187 IF IP=0 THEN PRINT "  Input: keyboard" ELSE PRINT "  Input: SERIAL(";IP;")"
188 IF CK=1 THEN PRINT "  CAPS: ON" ELSE PRINT "  CAPS: OFF"
192 GOSUB 900
195 REM === PAGE 3: SERIAL PORT ===
200 PRINT "  --Serial port--"
210 BD=PEEK(63480):BR=PEEK(63481)
215 IF BD=1 THEN B$="75"
216 IF BD=2 THEN B$="110"
217 IF BD=3 THEN B$="150"
220 IF BD=4 THEN B$="300"
230 IF BD=5 THEN B$="600"
240 IF BD=6 THEN B$="1200"
250 IF BD=7 THEN B$="2400"
255 IF BD=8 THEN B$="2400"
260 IF BD=9 THEN B$="4800"
270 IF BD<1 OR BD>9 THEN B$="?"+STR$(BD)
280 PRINT "  TX:";B$;"  RX:";BR
290 PRINT "  XON:";PEEK(63482);" CTS:";PEEK(63483);" DTR:";PEEK(63484);" DSR:";PEEK(63485);" DCD:";PEEK(63486)
310 PA=PEEK(63487)
320 IF PA=0 THEN PRINT "  Parity: none":PRINT:PRINT:PRINT:GOTO 345
330 PRINT "  Parity:";PA;" type:";PEEK(63488)
335 PRINT "  Echo:";PEEK(63493);" LF:";PEEK(63491)
336 TP=PEEK(63489):RP=PEEK(63494)
337 PRINT "  TX prot:";TP;" RX:";RP;
338 IF TP=0 THEN PRINT " none" ELSE IF TP=1 THEN PRINT " XON" ELSE IF TP=2 THEN PRINT " ETX" ELSE IF TP=3 THEN PRINT " ACK" ELSE PRINT ""
339 PRINT "  NULLs:";PEEK(63492);" IgnChr:";PEEK(63563)
345 GOSUB 900
350 REM === PAGE 4: SETTINGS & ACTIONS ===
355 PRINT "  --Settings--"
356 SF=PEEK(63507)
357 IF SF=170 THEN PRINT "  STARTFL: auto-run" ELSE PRINT "  STARTFL: no auto-run"
358 PRINT
365 PRINT "  Set 4800 baud? (Y/N)";
370 INCHR AK:PRINT CHR$(AK)
375 IF AK=89 OR AK=121 THEN POKE 63480,9:POKE 63481,9:PRINT "  Set to 4800"
376 PRINT
385 PRINT "  Switch to serial? (Y/N)";
390 INCHR AK:PRINT CHR$(AK)
395 IF AK<>89 AND AK<>121 THEN 500
400 POKE 63493,1:POKE 63360,128
410 PRINT "  Serial: cycle to reset"
415 INCHR AK
500 CLS:KEY ON:END
900 REM --- page break ---
910 PRINT "-- more --";
920 INCHR AK
930 CLS
940 RETURN
