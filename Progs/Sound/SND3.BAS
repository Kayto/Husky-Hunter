1 REM SND3 - Sound FX Sampler
2 REM Defend-game style sound effects
3 REM Keys: L=Laser X=Explode A=Alarm
4 REM       P=Pickup W=Win D=Death ESC=Exit
5 REM By kayto April 2026
6 KEY OFF:SCREEN 0:PRINT CHR$(1);
10 CHAR 1
12 PRINT "SND3: FX SAMPLER"
14 PRINT "================"
16 PRINT "[L]aser  [X]plode"
18 PRINT "[A]larm  [P]ickup"
20 PRINT "[W]in    [D]eath"
22 PRINT "[ESC] exit"
100 REM === Main key loop ===
110 A$=INKEY$:IF A$="" THEN 110
120 IF A$=CHR$(27) THEN GOTO 900
130 IF A$="L" OR A$="l" THEN GOSUB 200
140 IF A$="X" OR A$="x" THEN GOSUB 300
150 IF A$="A" OR A$="a" THEN GOSUB 400
160 IF A$="P" OR A$="p" THEN GOSUB 500
170 IF A$="W" OR A$="w" THEN GOSUB 600
180 IF A$="D" OR A$="d" THEN GOSUB 700
190 GOTO 110
200 REM === LASER: fast descending freq sweep ===
202 REM High freq (low pitch#) sweeps down to mid freq
204 FOR I=30 TO 100 STEP 4
206 SOUND I,7
208 NEXT I
210 RETURN
300 REM === EXPLOSION: irregular burst then rumble ===
302 SOUND 173,18:SOUND 341,12:SOUND 247,15:SOUND 412,10
304 SOUND 189,14:SOUND 303,11:SOUND 437,12:SOUND 261,16
306 SOUND 223,20:SOUND 367,14:SOUND 149,22:SOUND 391,12
310 RETURN
400 REM === ALARM: warbling alternating tones ===
402 FOR I=1 TO 8
404 SOUND 63,80
406 SOUND 90,80
408 NEXT I
410 RETURN
500 REM === PICKUP: rising arpeggio (C E G C) ===
502 SOUND 121,75
504 SOUND 95,75
506 SOUND 80,75
508 SOUND 59,110
510 RETURN
600 REM === WIN FANFARE: C D E G C (high) ===
602 SOUND 121,140
604 SOUND 107,120
606 SOUND 95,120
608 SOUND 80,120
610 SOUND 59,320
612 RETURN
700 REM === DEATH: descending slide to low ===
702 FOR I=50 TO 350 STEP 10
704 SOUND I,15
706 NEXT I
708 RETURN
900 SCREEN 0:PRINT CHR$(1);:CURON:END
