1 REM SND4 - Port 86H bit-bang sound (ROM truth)
2 REM ROM SOUND handler 83CAH uses OUT(86H) only
3 REM By Kayto April 2026
5 KEY OFF:SCREEN 0:PRINT CHR$(1);
8 REM Load 35 MC bytes at F605H (62981)
9 FOR I=0 TO 34:READ V:POKE 62981+I,V:NEXT I
10 CHAR 1
12 PRINT "SND4"
14 PRINT "Port 86H bit-bang"
16 PRINT "Same as BASIC SOUND"
18 PRINT ""
20 PRINT "Playing 6 notes..."
22 PRINT ""
30 FOR I=1 TO 6
32 READ PL,PH,DL,DH
34 POKE 63016,PL:POKE 63017,PH
36 POKE 63018,DL:POKE 63019,DH
38 X=CALL(62981)
40 NEXT I
50 PRINT "Done."
90 END
900 REM MC data (35 bytes, F605H)
902 DATA 42,40,246,235,42,42,246,235
904 DATA 175,211,134,68,77,11,120,177
906 DATA 32,251,62,1,211,134,68,77
908 DATA 11,120,177,32,251,27,122,179
910 DATA 32,230,201
920 REM Notes: PitchLo,PitchHi,DurLo,DurHi
922 DATA 144,0,200,0
924 DATA 121,0,200,0
926 DATA 107,0,200,0
928 DATA 95,0,200,0
930 DATA 80,0,200,0
932 DATA 71,0,200,0
