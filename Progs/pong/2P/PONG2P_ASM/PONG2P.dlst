441   558     62   1                               LD      A,MIN_ROW       ; clamp to 1
442   0230              row_ok:
443   560     50   6 246                        LD      (row),A
444   0233
445   0233              ; ============================================================
446   0233              ; 7.  Left paddle collision
447   0233              ;     Bounce dx if ball is at PADDLE_COL, moving left (dx = 0FFH),
448   0233              ;     and ball row is within py..py+PADDLE_HEIGHT-1 (with 3-row tolerance).
449   0233              ; ============================================================
450   563     58   5 246                        LD      A,(col)
451   566    254   4                               CP      PADDLE_COL
452   568     32  38                               JR      NZ,no_lpbounce
453   570     58   7 246                        LD      A,(dx)
454   573     60                                      INC     A               ; dx = 0FFH (-1)? -> INC gives 0
455   574     32  32                               JR      NZ,no_lpbounce  ; not moving left: no bounce
456   0240              ; ball+3 must be >= py (ball is not entirely above paddle)
457   576     58  15 246                        LD      A,(py)
458   579     71                                      LD      B,A
459   580     58   6 246                        LD      A,(row)
460   583    198   3                               ADD     A,3
461   585    184                                      CP      B               ; (row+3) vs py
462   586     56  20                               JR      C,no_lpbounce   ; row+3 < py: above paddle
463   024C              ; ball row must be < py+PADDLE_HEIGHT (ball is not entirely below paddle)
464   588     58  15 246                        LD      A,(py)
465   591    198  12                               ADD     A,PADDLE_HEIGHT
466   593     71                                      LD      B,A
467   594     58   6 246                        LD      A,(row)
468   597    184                                      CP      B               ; row vs py+HEIGHT
469   598     48   8                               JR      NC,no_lpbounce  ; row >= py+HEIGHT: below paddle
470   600     58   7 246                        LD      A,(dx)
471   603    237  68                               NEG
472   605     50   7 246                        LD      (dx),A          ; reverse dx
473   0260              no_lpbounce:
474   0260
475   0260              ; ============================================================
476   0260              ; 8.  Right paddle collision
477   0260              ;     Bounce dx if ball is at RIGHT_PADDLE_COL, moving right (dx = 01H),
478   0260              ;     and ball row overlaps opy..opy+PADDLE_HEIGHT-1 (with 3-row tolerance).
479   0260              ; ============================================================
480   608     58   5 246                        LD      A,(col)
481   611    254  25                               CP      RIGHT_PADDLE_COL
482   613     32  38                               JR      NZ,no_rpbounce
483   615     58   7 246                        LD      A,(dx)
484   618     61                                      DEC     A               ; dx = 01H (right)? -> DEC gives 0
485   619     32  32                               JR      NZ,no_rpbounce  ; not moving right: no bounce
486   621     58  17 246                        LD      A,(opy)
487   624     71                                      LD      B,A
488   625     58   6 246                        LD      A,(row)
489   628    198   3                               ADD     A,3
490   630    184                                      CP      B
491   631     56  20                               JR      C,no_rpbounce   ; row+3 < opy: above
492   633     58  17 246                        LD      A,(opy)
493   636    198  12                               ADD     A,PADDLE_HEIGHT
494   638     71                                      LD      B,A
495   639     58   6 246                        LD      A,(row)
496   642    184                                      CP      B
497   643     48   8                               JR      NC,no_rpbounce  ; row >= opy+HEIGHT: below
498   645     58   7 246                        LD      A,(dx)
499   648    237  68                               NEG
500   650     50   7 246                        LD      (dx),A
501   028D              no_rpbounce:
502   028D
503   028D              ; ============================================================
504   028D              ; 9.  Draw ball
505   028D              ;     Write the 4 sprite bytes to VRAM starting at (row, col).
506   028D              ; ============================================================
507   653     58   5 246                        LD      A,(col)
508   656     79                                      LD      C,A
509   657     58   6 246                        LD      A,(row)
510   660    205   1   3                        CALL    calc_vram       ; DE = VRAM offset
511   663     33   9 246                        LD      HL,sprite       ; HL -> sprite data (patched by BASIC)
512   666      6   4                               LD      B,4             ; 4 rows
513   029C
514   029C              draw_ball_loop:
515   668    197                                      PUSH    BC
516   669    205  20   3                        CALL    set_cursor
517   672    126                                      LD      A,(HL)
518   673     35                                      INC     HL
519   674    205  47   3                        CALL    write_byte
520   677    229                                      PUSH    HL
521   678    205 249   2                        CALL    next_row        ; DE += 30
522   681    225                                      POP     HL
523   682    193                                      POP     BC
524   683     16 239                               DJNZ    draw_ball_loop
525   02AD
526   685     62   0                               LD      A,00H
527   687    201                                      RET                     ; return to BASIC main loop
528   02B0
529   02B0              ; ============================================================
530   02B0              ; SUBROUTINE: erase_rows
531   02B0              ;   In:  B = row count,  DE = VRAM start address
532   02B0              ;   Writes 00H (erase) to B consecutive LCD rows.
533   02B0              ; ============================================================
534   02B0              erase_rows:
535   688    197                                      PUSH    BC
536   689    205  20   3                        CALL    set_cursor
537   692    175                                      XOR     A               ; 00H = erase
538   693    205  47   3                        CALL    write_byte
539   696    205 249   2                        CALL    next_row        ; DE += 30
540   699    193                                      POP     BC
541   700     16 242                               DJNZ    erase_rows
542   702    201                                      RET
543   02BF
544   02BF              ; ============================================================
545   02BF              ; SUBROUTINE: draw_rows
546   02BF              ;   In:  B = row count,  DE = VRAM start address
547   02BF              ;   Writes PADDLE_BYTE (0FFH) to B consecutive LCD rows.
548   02BF              ; ============================================================
549   02BF              draw_rows:
550   703    197                                      PUSH    BC
551   704    205  20   3                        CALL    set_cursor
552   707     62 255                               LD      A,PADDLE_BYTE   ; 0FFH = solid paddle pixel
553   709    205  47   3                        CALL    write_byte
554   712    205 249   2                        CALL    next_row
555   715    193                                      POP     BC
556   716     16 241                               DJNZ    draw_rows
557   718    201                                      RET
558   02CF
559   02CF              ; ============================================================
560   02CF              ; SUBROUTINE: draw_digit
561   02CF              ;   In:  A = digit (0..9),  C = byte-column
562   02CF              ;   Draws a SCORE_ROWS-tall digit from digit_font at LCD rows 0..6.
563   02CF              ;   Uses: all registers.  C must be set by caller before each call.
564   02CF              ; ============================================================
565   02CF              draw_digit:
566   719     95                                      LD      E,A             ; E = digit
567   720     22   0                               LD      D,0             ; DE = digit (16-bit)
568   722     98                                      LD      H,D             ; H = 0
569   723    107                                      LD      L,E             ; HL = digit
570   724     41                                      ADD     HL,HL           ; HL = digit * 2
571   725     25                                      ADD     HL,DE           ; HL = digit * 3
572   726     41                                      ADD     HL,HL           ; HL = digit * 6
573   727     25                                      ADD     HL,DE           ; HL = digit * 7  (byte offset in font)
574   728     17  68   3                        LD      DE,digit_font   ; DE = base address of font (patched by BASIC)
575   731     25                                      ADD     HL,DE           ; HL -> first byte of this digit's 7 rows
576   732    229                                      PUSH    HL              ; save font pointer
577   733     62   0                               LD      A,0             ; row 0 (top of screen)
578   735    205   1   3                        CALL    calc_vram       ; DE = VRAM(0, C)
579   738    225                                      POP     HL              ; restore font pointer
580   739      6   7                               LD      B,SCORE_ROWS    ; B = 7
581   02E5
582   02E5              draw_digit_loop:
583   741    197                                      PUSH    BC
584   742    229                                      PUSH    HL
585   743    205  20   3                        CALL    set_cursor
586   746    225                                      POP     HL
587   747    126                                      LD      A,(HL)          ; load font pixel row
588   748     35                                      INC     HL
589   749    205  47   3                        CALL    write_byte
590   752    229                                      PUSH    HL
591   753    205 249   2                        CALL    next_row        ; DE += 30
592   756    225                                      POP     HL
593   757    193                                      POP     BC
594   758     16 237                               DJNZ    draw_digit_loop
595   760    201                                      RET
596   02F9
597   02F9              ; ============================================================
598   02F9              ; SUBROUTINE: next_row
599   02F9              ;   In/Out: DE = VRAM address.  Advances DE by 30 (one LCD pixel-row).
600   02F9              ; ============================================================
601   02F9              next_row:
602   761     98                                      LD      H,D
603   762    107                                      LD      L,E
604   763     17  30   0                        LD      DE,001EH        ; 30 decimal
605   766     25                                      ADD     HL,DE
606   767    235                                      EX      DE,HL           ; DE = original + 30
607   768    201                                      RET
608   0301
609   0301              ; ============================================================
610   0301              ; SUBROUTINE: calc_vram
611   0301              ;   In:  A = pixel row (0..63),  C = byte-column (0..29)
612   0301              ;   Out: DE = row*30 + col  (HD61830 VRAM byte offset)
613   0301              ;   row*30 is computed as row*32 - row*2 using shift/subtract.
614   0301              ; ============================================================
615   0301              calc_vram:
616   769    111                                      LD      L,A             ; HL = row
617   770     38   0                               LD      H,0
618   772     41                                      ADD     HL,HL           ; row * 2
619   773    229                                      PUSH    HL              ; save row*2
620   774     41                                      ADD     HL,HL           ; row * 4
621   775     41                                      ADD     HL,HL           ; row * 8
622   776     41                                      ADD     HL,HL           ; row * 16
623   777     41                                      ADD     HL,HL           ; row * 32
624   778    209                                      POP     DE              ; DE = row * 2
625   779    183                                      OR      A               ; clear carry for SBC
626   780    237  82                               SBC     HL,DE           ; HL = row*32 - row*2 = row*30
627   782     89                                      LD      E,C             ; E = col
628   783     22   0                               LD      D,0
629   785     25                                      ADD     HL,DE           ; HL = row*30 + col
630   786    235                                      EX      DE,HL           ; DE = VRAM offset
631   787    201                                      RET
632   0314
633   0314              ; ============================================================
634   0314              ; SUBROUTINE: set_cursor
635   0314              ;   In:  DE = VRAM offset.
636   0314              ;   Writes cursor address (low then high) to HD61830 via ports 21H/20H.
637   0314              ;   Commands: 0AH = SET CURSOR ADDRESS (low byte)
638   0314              ;             0BH = SET CURSOR ADDRESS (high byte)
639   0314              ; ============================================================
640   0314              set_cursor:
641   788    205  62   3                        CALL    wait_busy
642   791     62  10                               LD      A,0AH           ; command: set cursor address low
643   793    211  33                               OUT     (21H),A
644   795    205  62   3                        CALL    wait_busy
645   798    123                                      LD      A,E             ; low byte of VRAM offset
646   799    211  32                               OUT     (20H),A
647   801    205  62   3                        CALL    wait_busy
648   804     62  11                               LD      A,0BH           ; command: set cursor address high
649   806    211  33                               OUT     (21H),A
650   808    205  62   3                        CALL    wait_busy
651   811    122                                      LD      A,D             ; high byte of VRAM offset
652   812    211  32                               OUT     (20H),A
653   814    201                                      RET
654   032F
655   032F              ; ============================================================
656   032F              ; SUBROUTINE: write_byte
657   032F              ;   In:  A = byte to write.
658   032F              ;   Sends WRITE DISPLAY DATA command (0CH) then the data byte.
659   032F              ; ============================================================
660   032F              write_byte:
661   815    245                                      PUSH    AF
662   816    205  62   3                        CALL    wait_busy
663   819     62  12                               LD      A,0CH           ; command: write display data
664   821    211  33                               OUT     (21H),A
665   823    205  62   3                        CALL    wait_busy
666   826    241                                      POP     AF
667   827    211  32                               OUT     (20H),A         ; write data byte
668   829    201                                      RET
669   033E
670   033E              ; ============================================================
671   033E              ; SUBROUTINE: wait_busy
672   033E              ;   Polls HD61830 status port 21H.  Bit 7 = busy flag.
673   033E              ;   Loops until bit 7 is clear (controller ready).
674   033E              ; ============================================================
675   033E              wait_busy:
676   830    219  33                               IN      A,(21H)
677   832      7                                      RLCA                    ; rotate bit 7 into carry
678   833     56 251                               JR      C,wait_busy     ; carry set = still busy
679   835    201                                      RET
680   0344
681   0344              ; ============================================================
682   0344              ; DATA: digit_font
683   0344              ;   10 digits x 7 rows = 70 bytes.
684   0344              ;   Each byte is one LCD row, bit 0 = leftmost pixel of the byte-column.
685   0344              ;   Digits 0-9, each 7 rows tall, drawn at rows 0..6 of the screen.
686   0344              ; ============================================================
687   0344              digit_font:
688   0344              ; 0: full box
689   836    124  68  68  68                  DB      7CH,44H,44H,44H,44H,44H,7CH
689   0348 44 44 7C
690   034B              ; 1: right-aligned vertical bar
691   843     16  24  16  16                  DB      10H,18H,10H,10H,10H,10H,38H
691   034F 10 10 38
692   0352              ; 2: top-right, middle, bottom-left
693   850    124  64  64 124                  DB      7CH,40H,40H,7CH,04H,04H,7CH
693   0356 04 04 7C
694   0359              ; 3: top-right, middle, bottom-right
695   857    124  64  64 124                  DB      7CH,40H,40H,7CH,40H,40H,7CH
695   035D 40 40 7C
696   0360              ; 4: top sides, middle, right bar
697   864     68  68  68 124                  DB      44H,44H,44H,7CH,40H,40H,00H
697   0364 40 40 00
698   0367              ; 5: top-left, middle, bottom-right
699   871    124   4   4 124                  DB      7CH,04H,04H,7CH,40H,40H,7CH
699   036B 40 40 7C
700   036E              ; 6: top-left, middle, full bottom
701   878    124   4   4 124                  DB      7CH,04H,04H,7CH,44H,44H,7CH
701   0372 44 44 7C
702   0375              ; 7: top bar, right bar
703   885    124  64  64  64                  DB      7CH,40H,40H,40H,40H,40H,00H
703   0379 40 40 00
704   037C              ; 8: full box with middle bar
705   892    124  68  68 124                  DB      7CH,44H,44H,7CH,44H,44H,7CH
705   0380 44 44 7C
706   0383              ; 9: top box, bottom-right
707   899    124  68  68 124                  DB      7CH,44H,44H,7CH,40H,40H,7CH
707   0387 40 40 7C
708   038A
# file closed: PONG2P.asm
