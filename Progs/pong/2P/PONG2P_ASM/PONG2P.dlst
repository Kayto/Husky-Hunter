 97   19     197                                      PUSH    BC
 98   20     205  20   3                        CALL    set_cursor      ; position HD61830 to DE
 99   23     121                                      LD      A,C             ; A = ball column
100   24     254  15                               CP      NET_COL
101   26      32   4                               JR      NZ,erase_zero
102   28      62  24                               LD      A,NET_BYTE      ; restore the two centre net pixels
103   30      24   1                               JR      erase_write
104   0020              erase_zero:
105   32     175                                      XOR     A               ; erase: write zero
106   0021              erase_write:
107   33     205  47   3                        CALL    write_byte
108   36     205 249   2                        CALL    next_row        ; DE += 30 (advance one LCD row)
109   39     193                                      POP     BC
110   40      16 233                               DJNZ    erase_ball_loop
