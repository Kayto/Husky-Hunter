147   0052              ; Ball overlaps left paddle column: full erase then full draw.
148   82      58  16 246                        LD      A,(old_py)
149   85      14   4                               LD      C,PADDLE_COL
150   87     205   1   3                        CALL    calc_vram
151   90       6  12                               LD      B,PADDLE_HEIGHT
152   92     205 176   2                        CALL    erase_rows
153   95      58  15 246                        LD      A,(py)
154   98      14   4                               LD      C,PADDLE_COL
155   100    205   1   3                        CALL    calc_vram
156   103      6  12                               LD      B,PADDLE_HEIGHT
157   105    205 191   2                        CALL    draw_rows
158   108     58  15 246                        LD      A,(py)
159   111     50  16 246                        LD      (old_py),A      ; save py -> old_py
160   114     24 114                               JR      lp_skip
161   0074
162   0074              lp_do_delta:
163   0074              ; Compute A = old_py - py (signed).
164   0074              ; No carry (>= 0): old_py > py -> paddle moved up.
165   0074              ; Carry set (< 0): old_py < py -> paddle moved down.
166   0074              ; Zero: no change.
167   116     58  15 246                        LD      A,(py)
168   119     71                                      LD      B,A             ; B = py
169   120     58  16 246                        LD      A,(old_py)
170   123    144                                      SUB     B               ; A = old_py - py
171   124     40 104                               JR      Z,lp_skip       ; no movement
172   126     56  46                               JR      C,lp_moved_down ; carry: old_py < py -> moved down
173   0080
174   0080              ; --- Paddle moved up (no carry: old_py > py, A = positive delta) ---
175   0080              ; Erase delta rows at the bottom of the old position: old_py + HEIGHT - delta
176   0080              ; Draw  delta rows at the top of the new position:    py
177   128     79                                      LD      C,A             ; C = delta (save before clobbering A)
178   129     58  16 246                        LD      A,(old_py)
179   132    198  12                               ADD     A,PADDLE_HEIGHT
180   134    145                                      SUB     C               ; A = old_py + HEIGHT - delta = py + HEIGHT
181   135     14   4                               LD      C,PADDLE_COL
182   137    205   1   3                        CALL    calc_vram       ; DE = VRAM(py+HEIGHT, PADDLE_COL)
183   008C              ; Recompute delta into B (C was clobbered by LD C,PADDLE_COL; calc_vram preserves B)
184   140     58  15 246                        LD      A,(py)
185   143     71                                      LD      B,A
186   144     58  16 246                        LD      A,(old_py)
187   147    144                                      SUB     B               ; A = delta
188   148     71                                      LD      B,A
189   149    205 176   2                        CALL    erase_rows      ; erase delta rows at old bottom
190   152     58  15 246                        LD      A,(py)
191   155     14   4                               LD      C,PADDLE_COL
192   157    205   1   3                        CALL    calc_vram       ; DE = VRAM(py, PADDLE_COL)
193   160     58  15 246                        LD      A,(py)
194   163     71                                      LD      B,A
195   164     58  16 246                        LD      A,(old_py)
196   167    144                                      SUB     B               ; A = delta
197   168     71                                      LD      B,A
198   169    205 191   2                        CALL    draw_rows       ; draw delta rows at new top
199   172     24  50                               JR      lp_done
