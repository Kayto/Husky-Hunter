113   002A              ; 2.5. Conditional score draw
114   002A              ;      Always draw if score_dirty != 0.
115   002A              ;      Also draw if ball row < SCORE_ROWS (ball overlaps digit area).
116   002A              ; ============================================================
117   42      58  22 246                        LD      A,(score_dirty)
118   45     183                                      OR      A
119   46      32   7                               JR      NZ,do_scores    ; dirty flag set: draw unconditionally
120   48      58   6 246                        LD      A,(row)         ; check whether ball overlaps score rows
121   51     254   7                               CP      SCORE_ROWS      ; carry set if row < SCORE_ROWS
122   53      48  20                               JR      NC,skip_scores  ; no overlap: skip
123   0037
124   0037              do_scores:
125   55      58  20 246                        LD      A,(S1)
126   58      14   7                               LD      C,P1_SCORE_COL
127   60     205 207   2                        CALL    draw_digit      ; draw left score
128   63      58  21 246                        LD      A,(S2)
129   66      14  22                               LD      C,P2_SCORE_COL
130   68     205 207   2                        CALL    draw_digit      ; draw right score
131   71     175                                      XOR     A
132   72      50  22 246                        LD      (score_dirty),A ; clear dirty flag
