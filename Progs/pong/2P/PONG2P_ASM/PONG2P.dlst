 82   0004              ; ============================================================
 83   0004              ; 2.  Erase ball
 84   0004              ;     Overwrite the 4 rows the ball occupies with 0, except at
 85   0004              ;     NET_COL where NET_BYTE (18H) is written to restore the net.
 86   0004              ; ============================================================
 87   4       58   6 246                        LD      A,(row)
 88   7       79                                      LD      C,A             ; C = row (temporary)
 89   8       58   5 246                        LD      A,(col)
 90   11      71                                      LD      B,A             ; B = col (temporary)
 91   12     121                                      LD      A,C             ; A = row
 92   13      72                                      LD      C,B             ; C = col
 93   14     205   1   3                        CALL    calc_vram       ; DE = VRAM offset for (row, col)
 94   17       6   4                               LD      B,4             ; ball is 4 rows tall
