201   00AE              lp_moved_down:
202   00AE              ; Carry: old_py < py -> paddle moved down.  NEG gives |delta| = py - old_py.
203   174    237  68                               NEG                     ; A = |delta|
204   176     71                                      LD      B,A             ; B = |delta| (calc_vram preserves B)
205   00B1              ; Erase |delta| rows at the top of the old position: old_py
206   177     58  16 246                        LD      A,(old_py)
207   180     14   4                               LD      C,PADDLE_COL
208   182    205   1   3                        CALL    calc_vram       ; B = |delta| unchanged
209   185    205 176   2                        CALL    erase_rows      ; erase |delta| rows at old top
210   00BC              ; Draw |delta| rows at the new bottom: py + HEIGHT - |delta|
211   188     58  15 246                        LD      A,(py)
212   191     71                                      LD      B,A             ; B = py
213   192     58  16 246                        LD      A,(old_py)
214   195    144                                      SUB     B               ; old_py - py (negative)
215   196    237  68                               NEG                     ; |delta|
216   198     79                                      LD      C,A             ; C = |delta|
217   199     58  15 246                        LD      A,(py)
