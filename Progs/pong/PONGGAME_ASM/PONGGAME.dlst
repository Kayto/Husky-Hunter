154   0091              ; Moved down: erase PADDLE_SPEED rows at top of old, draw at bottom of new.
155   145    120                                      LD      A,B             ; A = old_py (top of old paddle)
156   146     14   1                               LD      C,PADDLE_COL
157   148    205 128   1                        CALL    calc_vram
158   151      6   4                               LD      B,PADDLE_SPEED
159   153    205  89   1                        CALL    erase_rows
160   156     58  15 246                        LD      A,(py)
161   159    198   8                               ADD     A,PADDLE_HEIGHT-PADDLE_SPEED  ; bottom section start
162   161     14   1                               LD      C,PADDLE_COL
163   163    205 128   1                        CALL    calc_vram
164   166      6   4                               LD      B,PADDLE_SPEED
165   168    205 104   1                        CALL    draw_rows
166   171     24  26                               JR      skip_paddle
167   00AD
168   00AD              moved_up:
169   00AD              ; Moved up: erase PADDLE_SPEED rows at bottom of old, draw at top of new.
170   173    120                                      LD      A,B             ; B = old_py
171   174    198   8                               ADD     A,PADDLE_HEIGHT-PADDLE_SPEED  ; bottom section start
172   176     14   1                               LD      C,PADDLE_COL
173   178    205 128   1                        CALL    calc_vram
174   181      6   4                               LD      B,PADDLE_SPEED
175   183    205  89   1                        CALL    erase_rows
176   186     58  15 246                        LD      A,(py)          ; new top
177   189     14   1                               LD      C,PADDLE_COL
178   191    205 128   1                        CALL    calc_vram
179   194      6   4                               LD      B,PADDLE_SPEED
180   196    205 104   1                        CALL    draw_rows
