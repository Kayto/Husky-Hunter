221   0101              ; -------- PADDLE COLLISION CHECK --------
222   0101              ; Conditions: col == PADDLE_COL, dx == -1 (moving left), row overlaps paddle.
223   257     58   5 246                        LD      A,(col)
224   260    254   1                               CP      PADDLE_COL
225   262     32  38                               JR      NZ,no_pbounce
226   264     58   7 246                        LD      A,(dx)
227   267     60                                      INC     A               ; 0FFH+1=00H: only 0FFH (-1) wraps to 0
228   268     32  32                               JR      NZ,no_pbounce   ; dx != -1: ball moving right, skip
229   010E
230   270     58  15 246                        LD      A,(py)
231   273     71                                      LD      B,A             ; B = py
232   274     58   6 246                        LD      A,(row)
233   277    198   3                               ADD     A,3             ; A = row+3 (ball bottom edge)
234   279    184                                      CP      B               ; (row+3) - py
235   280     56  20                               JR      C,no_pbounce    ; ball entirely above paddle
236   011A
237   282     58  15 246                        LD      A,(py)
238   285    198  12                               ADD     A,PADDLE_HEIGHT ; A = py + 12
239   287     71                                      LD      B,A
240   288     58   6 246                        LD      A,(row)
241   291    184                                      CP      B               ; row - (py+12)
242   292     48   8                               JR      NC,no_pbounce   ; ball entirely below paddle
243   0126
244   0126                              ; Overlap: reverse dx
245   294     58   7 246                        LD      A,(dx)
246   297    237  68                               NEG
247   299     50   7 246                        LD      (dx),A
248   012E              no_pbounce:
