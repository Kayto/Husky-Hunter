  1   0000              ; PONGGAME.asm - Ball + net + left paddle with collision
  2   0000              ; Z80 source equivalent of gen_ponggame.py
  3   0000              ; By Kayto April 2026
  4   0000              ;
  5   0000              ; Assembler: compatible with Pasmo / SJASM+  (Intel-style, H-suffix hex)
  6   0000              ;
  7   0000              ; MC stored in DIM/VARPTR string array (DIM MC$(D,1), AD=VARPTR(MC$)-1).
  8   0000              ; Assembled with base=0. All internal CALL/JP targets are offset-from-start.
  9   0000              ; BASIC patches them to real addresses at runtime before CALL(AD).
 10   0000              ; EXCEPTION: CALL 0005H (BDOS) is NOT patched - 0005H is the real CP/M vector.
 11   0000              ;
 12   0000              ; Param block at F605H (62981) - fixed user code area (12 bytes):
 13   0000              ;   +0     : col      (byte column, 0-29)
 14   0000              ;   +1     : row      (pixel row, 0-60)
 15   0000              ;   +2     : dx       (column delta: 1 or 0FFH = -1)
 16   0000              ;   +3     : dy       (row delta:    1 or 0FFH = -1)
 17   0000              ;   +4..+7 : sprite   (4 ball pattern bytes)
 18   0000              ;   +8,+9  : delay    (frame delay counter, little-endian word)
 19   0000              ;   +10    : py       (paddle Y, pixel row, 0-52)
 20   0000              ;   +11    : old_py   (previous py, written by MC each frame)
 21   0000
 22   0000              PARAM_BASE      EQU     0F605H
 23   0000
 24   0000              PADDLE_HEIGHT   EQU     12      ; paddle height in pixel rows
 25   0000              PADDLE_SPEED    EQU     4       ; pixels per keypress
 26   0000              PADDLE_COL      EQU     1       ; left paddle column
 27   0000              MAX_PADDLE_Y    EQU     52      ; 64 - PADDLE_HEIGHT
 28   0000              MAX_COL         EQU     29
 29   0000              MAX_ROW         EQU     60
 30   0000              NET_COL         EQU     15      ; centre column
 31   0000              NET_BYTE        EQU     18H     ; centre 2 bits
 32   0000              PADDLE_BYTE     EQU     0FFH    ; full byte (8 pixels wide)
 33   0000              KEY_ESC         EQU     1BH
 34   0000              KEY_A           EQU     61H     ; 'a' after OR 20H (case-insensitive)
 35   0000              KEY_Z           EQU     7AH     ; 'z' after OR 20H
 36   0000
 37   0000              col             EQU     PARAM_BASE + 0
 38   0000              row             EQU     PARAM_BASE + 1
 39   0000              dx              EQU     PARAM_BASE + 2
 40   0000              dy              EQU     PARAM_BASE + 3
 41   0000              sprite          EQU     PARAM_BASE + 4
 42   0000              delay_ctr       EQU     PARAM_BASE + 8
 43   0000              py              EQU     PARAM_BASE + 10
 44   0000              old_py          EQU     PARAM_BASE + 11
 45   0000
 46   0000              ; NOTE: ORG is base=0 here for clarity.
 47   0000              ; At runtime BASIC adds AD (the DIM/VARPTR address) to all CALL/JP targets.
 48   0000                              ORG     0000H
 49   0000
 50   0000              ; ==================== INITIAL PADDLE DRAW ====================
 51   0000              ; Drawn once before main loop; falls straight through.
 52   0       58  15 246                        LD      A,(py)
 53   3       14   1                               LD      C,PADDLE_COL
 54   5      205 128   1                        CALL    calc_vram       ; DE = VRAM addr for top of paddle
 55   8        6  12                               LD      B,PADDLE_HEIGHT
 56   10     205 104   1                        CALL    draw_rows       ; write 0FFH to B rows
 57   000D
 58   000D              ; ==================== MAIN LOOP ====================
 59   000D              main_loop:
 60   13      58  15 246                        LD      A,(py)          ; save py for differential update
 61   16      50  16 246                        LD      (old_py),A
 62   0013
 63   0013              ; -------- KEY CHECK (non-blocking BDOS fn 11) --------
 64   19      14  11                               LD      C,0BH
 65   21     205   5   0                        CALL    0005H           ; BDOS fn11: console status
 66   24     167                                      AND     A
 67   25      40  48                               JR      Z,no_key        ; no key pending
 68   001B
 69   001B              ; -------- READ KEY (BDOS fn 6, direct I/O) --------
 70   27      14   6                               LD      C,06H
 71   29      30 255                               LD      E,0FFH
 72   31     205   5   0                        CALL    0005H           ; A = key char
 73   0022
 74   34     254  27                               CP      KEY_ESC
 75   36      32   1                               JR      NZ,not_esc
 76   38     201                                      RET                     ; ESC: return to BASIC
 77   0027
 78   0027              not_esc:
 79   39     246  32                               OR      20H             ; force lowercase (case-insensitive)
 80   41     254  97                               CP      KEY_A
 81   43      40   6                               JR      Z,paddle_up
 82   45     254 122                               CP      KEY_Z
 83   47      40  12                               JR      Z,paddle_down
 84   49      24  24                               JR      no_key
 85   0033
 86   0033              paddle_up:
 87   51      58  15 246                        LD      A,(py)
 88   54     214   4                               SUB     PADDLE_SPEED
 89   56      48  14                               JR      NC,paddle_store
 90   58     175                                      XOR     A               ; clamp to 0
 91   59      24  11                               JR      paddle_store
 92   003D
 93   003D              paddle_down:
 94   61      58  15 246                        LD      A,(py)
 95   64     198   4                               ADD     A,PADDLE_SPEED
 96   66     254  53                               CP      MAX_PADDLE_Y+1
 97   68      56   2                               JR      C,paddle_store
 98   70      62  52                               LD      A,MAX_PADDLE_Y  ; clamp to 52
