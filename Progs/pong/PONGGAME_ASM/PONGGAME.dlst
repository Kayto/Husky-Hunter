251   302     58   5 246                        LD      A,(col)
252   305     79                                      LD      C,A
253   306     58   6 246                        LD      A,(row)
254   309    205 128   1                        CALL    calc_vram
255   312     33   9 246                        LD      HL,sprite
256   315      6   4                               LD      B,4
