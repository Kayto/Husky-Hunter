182   00C7              skip_paddle:
183   00C7
184   00C7              ; -------- UPDATE col (horizontal bounce, wall 0 and 29) --------
185   199     58   5 246                        LD      A,(col)
186   202     71                                      LD      B,A
187   203     58   7 246                        LD      A,(dx)
188   206    128                                      ADD     A,B             ; A = col + dx (unsigned)
189   207    254  30                               CP      MAX_COL+1
190   209     56   9                               JR      C,col_ok
191   211     58   7 246                        LD      A,(dx)
192   214    237  68                               NEG                     ; reverse direction
193   216     50   7 246                        LD      (dx),A
194   219    128                                      ADD     A,B             ; recompute with new dx
195   00DC              col_ok:
196   220     50   5 246                        LD      (col),A
197   00DF
198   00DF              ; -------- BEEP ON MISS --------
199   00DF              ; col == 0 means ball reached left wall (missed paddle).
200   223    183                                      OR      A               ; Z if col = 0
201   224     32   7                               JR      NZ,no_beep
202   226     14   2                               LD      C,02H           ; BDOS fn2: console output
203   228     30   7                               LD      E,07H           ; BEL
204   230    205   5   0                        CALL    0005H
205   00E9              no_beep:
206   00E9
207   00E9              ; -------- UPDATE row (vertical bounce, wall 0 and 60) --------
208   233     58   6 246                        LD      A,(row)
209   236     71                                      LD      B,A
210   237     58   8 246                        LD      A,(dy)
211   240    128                                      ADD     A,B
212   241    254  61                               CP      MAX_ROW+1
213   243     56   9                               JR      C,row_ok
214   245     58   8 246                        LD      A,(dy)
215   248    237  68                               NEG
216   250     50   8 246                        LD      (dy),A
217   253    128                                      ADD     A,B
218   00FE              row_ok:
219   254     50   6 246                        LD      (row),A
