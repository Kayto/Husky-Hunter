302   372    193                                      POP     BC
303   373     16 241                               DJNZ    draw_rows
304   375    201                                      RET
305   0178
306   0178              ; next_row: DE += 30  (advance one LCD row)
307   0178              ; Clobbers HL.  Preserves DE value after add.
308   0178              next_row:
309   376     98                                      LD      H,D
310   377    107                                      LD      L,E
311   378     17  30   0                        LD      DE,30
312   381     25                                      ADD     HL,DE
313   382    235                                      EX      DE,HL
314   383    201                                      RET
315   0180
316   0180              ; calc_vram: A=row, C=col -> DE = row*30 + col
317   0180              ; row*30 = row*32 - row*2
318   0180              ; Clobbers A,HL,DE.  Preserves B,C
319   0180              calc_vram:
320   384    111                                      LD      L,A
321   385     38   0                               LD      H,0
322   387     41                                      ADD     HL,HL           ; row*2
323   388    229                                      PUSH    HL
324   389     41                                      ADD     HL,HL           ; row*4
325   390     41                                      ADD     HL,HL           ; row*8
326   391     41                                      ADD     HL,HL           ; row*16
327   392     41                                      ADD     HL,HL           ; row*32
328   393    209                                      POP     DE
329   394    183                                      OR      A               ; OR A: clears carry flag without changing A
330   395    237  82                               SBC     HL,DE           ; HL = row*30
331   397     89                                      LD      E,C
332   398     22   0                               LD      D,0
333   400     25                                      ADD     HL,DE
334   401    235                                      EX      DE,HL           ; DE = VRAM addr
