282   0159              ; erase_rows: write 0 to B rows starting at DE
283   0159              ; Clobbers A,DE,BC
284   0159              erase_rows:
285   345    197                                      PUSH    BC
286   346    205 147   1                        CALL    set_cursor
287   349    175                                      XOR     A
288   350    205 174   1                        CALL    write_byte
289   353    205 120   1                        CALL    next_row
290   356    193                                      POP     BC
291   357     16 242                               DJNZ    erase_rows
292   359    201                                      RET
293   0168
294   0168              ; draw_rows: write 0FFH to B rows starting at DE
295   0168              ; Clobbers A,DE,BC
296   0168              draw_rows:
297   360    197                                      PUSH    BC
298   361    205 147   1                        CALL    set_cursor
299   364     62 255                               LD      A,PADDLE_BYTE
300   366    205 174   1                        CALL    write_byte
