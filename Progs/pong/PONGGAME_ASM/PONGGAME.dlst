116   005A              erase_ball_loop:
117   90     197                                      PUSH    BC
118   91     205 147   1                        CALL    set_cursor
119   94     121                                      LD      A,C             ; C = col (preserved by set_cursor)
120   95     254  15                               CP      NET_COL
121   97      32   4                               JR      NZ,erase_ball_zero
122   99      62  24                               LD      A,NET_BYTE      ; restore net column
123   101     24   1                               JR      erase_ball_write
124   0067              erase_ball_zero:
125   103    175                                      XOR     A
126   0068              erase_ball_write:
127   104    205 174   1                        CALL    write_byte
128   107    205 120   1                        CALL    next_row        ; DE += 30
129   110    193                                      POP     BC
130   111     16 233                               DJNZ    erase_ball_loop
131   0071
132   0071              ; -------- PADDLE FIX --------
133   0071              ; If ball was on paddle column, the erase above wiped paddle pixels.
134   0071              ; Redraw full paddle at current py before the differential update.
135   113     58   5 246                        LD      A,(col)         ; old ball column
136   116    254   1                               CP      PADDLE_COL
137   118     32  13                               JR      NZ,no_paddle_fix
138   120     58  15 246                        LD      A,(py)
139   123     14   1                               LD      C,PADDLE_COL
140   125    205 128   1                        CALL    calc_vram
141   128      6  12                               LD      B,PADDLE_HEIGHT
142   130    205 104   1                        CALL    draw_rows
143   0085              no_paddle_fix:
144   0085
145   0085              ; -------- DIFFERENTIAL PADDLE UPDATE --------
146   0085              ; Only redraw the rows that actually changed (PADDLE_SPEED rows at each end).
147   133     58  16 246                        LD      A,(old_py)
148   136     71                                      LD      B,A             ; B = old_py
149   137     58  15 246                        LD      A,(py)
150   140    184                                      CP      B
151   141     40  56                               JR      Z,skip_paddle   ; py unchanged
152   143     56  28                               JR      C,moved_up      ; new py < old py: moved up
