105   004B              ; -------- ERASE BALL --------
106   004B              ; Restore net byte at NET_COL, zero elsewhere.
107   75      58   6 246                        LD      A,(row)
108   78      79                                      LD      C,A
109   79      58   5 246                        LD      A,(col)
110   82      71                                      LD      B,A
111   83     121                                      LD      A,C             ; A = row, C = col
112   84      72                                      LD      C,B
113   85     205 128   1                        CALL    calc_vram       ; DE = VRAM addr
114   88       6   4                               LD      B,4
